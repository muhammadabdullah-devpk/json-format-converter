run = "python main.py"
entrypoint = "main.py"
modules = ["python-3.12"]

[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[deployment]
deploymentTarget = "vm"
run = ["python", "main.py"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"

[workflows.workflow.metadata]
outputType = "console"
